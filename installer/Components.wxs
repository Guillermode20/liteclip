<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <!-- Main application binary component (one executable = one component) -->
    <Component Id="cmpLiteClipExe" Guid="{A1F2C3D4-E5F6-4710-9ABC-DEF012345678}" Directory="INSTALLDIR">
      <File Id="filLiteClipExe" Source="..\target\release\liteclip-replay.exe" KeyPath="yes" />
    </Component>

    <!-- Core component group contains required runtime components + shortcuts/registry (refs supplied below) -->
    <ComponentGroup Id="CoreComponents">
      <ComponentRef Id="cmpLiteClipExe" />
      <ComponentRef Id="cmpStartMenuShortcut" />
      <ComponentRef Id="cmpUninstallShortcut" />
      <ComponentRef Id="cmpDesktopShortcut" />
      <ComponentRef Id="cmpFileAssocHKLM" />
      <ComponentRef Id="cmpARP" />
      <ComponentGroupRef Id="AppHarvestedComponents" />
    </ComponentGroup>

    <!-- FFmpeg DLLs for native ffmpeg-next linking -->
    <ComponentGroup Id="FFmpegComponents" Directory="INSTALLDIR">
      <Component Id="cmp_avcodec_61" Guid="{B1A2C3D4-E5F6-7890-ABCD-EF1234567890}">
        <File Id="fil_avcodec_61" Source="..\ffmpeg_dev\sdk\bin\avcodec-61.dll" />
      </Component>
      <Component Id="cmp_avformat_61" Guid="{C2B3D4E5-F6A7-8901-BCDE-F23456789012}">
        <File Id="fil_avformat_61" Source="..\ffmpeg_dev\sdk\bin\avformat-61.dll" />
      </Component>
      <Component Id="cmp_avutil_59" Guid="{D3C4E5F6-A7B8-9012-CDEF-345678901234}">
        <File Id="fil_avutil_59" Source="..\ffmpeg_dev\sdk\bin\avutil-59.dll" />
      </Component>
      <Component Id="cmp_swresample_5" Guid="{A5B6C7D8-E9F0-1234-5678-9ABCDEF01234}">
        <File Id="fil_swresample_5" Source="..\ffmpeg_dev\sdk\bin\swresample-5.dll" />
      </Component>
      <Component Id="cmp_swscale_8" Guid="{E4D5F6A7-B8C9-0123-DEF0-456789012345}">
        <File Id="fil_swscale_8" Source="..\ffmpeg_dev\sdk\bin\swscale-8.dll" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="AppHarvestedComponents" />
  </Fragment>
</Wix>