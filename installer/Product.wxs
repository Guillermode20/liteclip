<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="$(var.ProductName)"
    Manufacturer="$(var.Manufacturer)"
    Version="$(var.ProductVersion)"
    UpgradeCode="{6A9F2B9F-8C31-4C0A-9A4B-2F3A5E4D6B7C}"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of LiteClip is already installed." Schedule="afterInstallValidate" AllowSameVersionUpgrades="no" />
    <MediaTemplate EmbedCab="yes" />
    <Property Id="ARPNOREMOVE" Value="0" />
    <Icon Id="AppIcon" SourceFile="..\logo.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <!-- Feature tree references component groups declared elsewhere -->
    <Feature Id="ProductFeature" Title="$(var.ProductName)" Level="1" Display="expand">
      <ComponentGroupRef Id="CoreComponents" />
      <ComponentGroupRef Id="FFmpegComponents" />
      <FeatureRef Id="DesktopShortcutFeature" />
    </Feature>
  </Package>
</Wix>
