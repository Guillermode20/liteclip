<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <!-- Program Files (x64) install location -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="LiteClip" />
    </StandardDirectory>

    <!-- Start Menu shortcuts -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="LiteClip">
        <Directory Id="ProgramMenuShortcuts" Name="LiteClip" />
      </Directory>
    </StandardDirectory>

    <!-- Optional desktop shortcut -->
    <StandardDirectory Id="DesktopFolder" />
  </Fragment>
</Wix>
