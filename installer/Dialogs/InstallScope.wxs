<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <UI>
      <!-- Simplified InstallScope dialog: sets ALLUSERS property -->
      <Dialog Id="InstallScopeDlg" Width="370" Height="270" Title="[ProductName] - Choose Installation Scope">
      <Control Id="Heading" Type="Text" X="15" Y="15" Width="340" Height="40" Transparent="yes" NoPrefix="yes" Text="Choose whether to install for all users or only for the current user." />

      <Control Id="AllUsersGroup" Type="RadioButtonGroup" X="15" Y="80" Width="340" Height="60" Property="ALLUSERS">
        <RadioButtonGroup Property="ALLUSERS">
          <RadioButton Value="1" X="0" Y="0" Width="320" Height="17" Text="Install for all users (requires administrator rights)" />
          <RadioButton Value="0" X="0" Y="20" Width="320" Height="17" Text="Install for only me (no administrator rights)" />
        </RadioButtonGroup>
      </Control>

      <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back">
        <Publish Event="NewDialog" Value="WelcomeDlg" />
      </Control>
      <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="Next">
        <Publish Event="NewDialog" Value="CustomizeDlg" />
      </Control>
      <Control Id="Cancel" Type="PushButton" X="296" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
        <Publish Event="SpawnDialog" Value="CancelDlg" />
      </Control>
    </Dialog>
    </UI>
  </Fragment>
</Wix>
